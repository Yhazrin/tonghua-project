# ============================================
# VICOO — Environment Variables for Easy Deploy
# All secrets are pre-generated for demo use.
# Change them before any production deployment.
# ============================================

# Application
APP_ENV=development
APP_NAME=VICOO API

# MySQL
MYSQL_ROOT_PASSWORD=vicoo_root_pass_2026
MYSQL_DATABASE=vicoo
MYSQL_USER=vicoo
MYSQL_PASSWORD=vicoo_pass_2026

# Secrets (pre-generated -- safe for demo only)
# Generate new ones with: openssl rand -hex 32
APP_SECRET_KEY=a3f8c2b1e9d7m4n6p8q0r2s5t7u9x1z3a5c7e9f2g4h6i0j8l2m
ENCRYPTION_KEY=b4d7e1h5j9k2n6m8p1q3r7s9t2u4v6x8z0a2c4e6f8g1j3l5n7p9

# JWT
JWT_ALGORITHM=HS256

# CORS
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:8080,http://127.0.0.1

# Frontend (for local .env if not using docker default)
VITE_API_BASE_URL=/api/v1

# Seed passwords (demo accounts)
SEED_ADMIN_PASSWORD=vicoo-admin
SEED_EDITOR_PASSWORD=vicoo-editor
SEED_USER_PASSWORD=vicoo-user
MOCK_USER_PASSWORD=vicoo-mock
