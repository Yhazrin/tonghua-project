# ============================================
# VICOO — Environment Variables for Easy Deploy
# All secrets are pre-generated for demo use.
# Change them before any production deployment.
# ============================================

# Application
APP_ENV=development
APP_NAME=VICOO API

# MySQL
MYSQL_ROOT_PASSWORD=vicoo_root_pass_2026
MYSQL_DATABASE=vicoo
MYSQL_USER=vicoo
MYSQL_PASSWORD=vicoo_pass_2026

# Secrets (pre-generated -- safe for demo only)
# Generate new ones with: openssl rand -hex 32
APP_SECRET_KEY=a3f8c2b1e9d7m4n6p8q0r2s5t7u9x1z3a5c7e9f2g4h6i0j8l2m
ENCRYPTION_KEY=b4d7e1h5j9k2n6m8p1q3r7s9t2u4v6x8z0a2c4e6f8g1j3l5n7p9

# JWT
JWT_ALGORITHM=HS256

# CORS
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:8080,http://127.0.0.1, http://localhost:8000, http://localhost:5173, http://localhost:9111

# Frontend (for local .env if not using docker default)
VITE_API_BASE_URL=/api

# Seed passwords (demo accounts)
SEED_ADMIN_PASSWORD=vicoo-admin
SEED_EDITOR_PASSWORD=vicoo-editor
SEED_USER_PASSWORD=vicoo-user
MOCK_USER_PASSWORD=vicoo-mock

# Resend Mailer (Optional)
RESEND_API_KEY=re_your_api_key_here
MAIL_FROM=VICOO <onboarding@vicoo.yhazrin.xyz>

# AI — OpenAI (Required for AI features)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Redis (Optional but recommended for production)
REDIS_URL=redis://redis:6379/0

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub (需要填写)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Payments — WeChat Pay (Mini Program / JSAPI)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_NOTIFY_URL=http://localhost:8000/api/v1/payments/wechat-notify

# Payments — Alipay (Web)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=http://localhost:8000/api/v1/payments/alipay-notify

# Frontend URL (for OAuth callback redirect)
FRONTEND_URL=http://localhost
