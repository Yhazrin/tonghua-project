# ============================================
# Tonghua Public Welfare — Backend Environment Variables
# ============================================

# --- Application ---
APP_NAME=Tonghua API
APP_ENV=development
DEBUG=false

# --- Database (MySQL 8.0) ---
# Format: mysql+aiomysql://user:password@host:port/database
DATABASE_URL=mysql+aiomysql://tonghua:change-me@localhost:3306/tonghua
DB_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Configuration ---
# IMPORTANT: Use strong RSA keys for RS256 algorithm (recommended for production)
# Generate RSA keys with:
# openssl genpkey -algorithm RSA -out jwt_private_key.pem -pkeyopt rsa_keygen_bits:2048
# openssl rsa -in jwt_private_key.pem -pubout -out jwt_public_key.pem
# Or use HS256 for development (less secure):
# Generate with: openssl rand -hex 32
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY=your-rsa-private-key-pem
JWT_PUBLIC_KEY=your-rsa-public-key-pem
APP_SECRET_KEY=your-secret-key-change-in-production  # For HS256 fallback
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AES Encryption ---
# IMPORTANT: Must be exactly 32 bytes (64 hex characters) for AES-256
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-change-in-production

# --- CORS Configuration ---
# Comma-separated list of allowed origins
# Use "*" for development only (not recommended for production)
# Format: https://localhost:5173,https://your-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3003

# --- WeChat Configuration ---
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_MCH_ID=  # WeChat Pay Merchant ID
WECHAT_PAY_API_KEY=  # WeChat Pay API Key
WECHAT_NOTIFY_URL=  # WeChat Pay callback URL

# --- Rate Limiting ---
GLOBAL_RATE_LIMIT=1000
USER_RATE_LIMIT=60

# --- Admin Configuration ---
ADMIN_EMAIL=admin@tonghua.org

# --- Seed Data Passwords (for development/testing only) ---
# IMPORTANT: Use strong, unique passwords in production
# Generate with: openssl rand -base64 32
SEED_ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_HERE
SEED_EDITOR_PASSWORD=YOUR_EDITOR_PASSWORD_HERE
SEED_USER_PASSWORD=YOUR_USER_PASSWORD_HERE
