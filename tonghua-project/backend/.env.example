# ============================================
# Tonghua Public Welfare — Backend Environment Variables
# ============================================

# --- Application ---
APP_NAME=Tonghua API
APP_ENV=development
DEBUG=false

# --- Database (MySQL 8.0) ---
# Format: mysql+aiomysql://user:password@host:port/database
DATABASE_URL=mysql+aiomysql://tonghua:change-me@localhost:3306/tonghua
DB_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Configuration ---
# IMPORTANT: Use a strong random secret key (at least 32 characters)
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AES Encryption ---
# IMPORTANT: Must be exactly 32 bytes (64 hex characters) for AES-256
# Generate with: openssl rand -hex 32
AES_KEY=your-32-byte-hex-encryption-key-change-in-production

# --- CORS Configuration ---
# Comma-separated list of allowed origins
# Use "*" for development only (not recommended for production)
# Format: https://localhost:5173,https://your-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- WeChat Configuration ---
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# --- Rate Limiting ---
GLOBAL_RATE_LIMIT=1000
USER_RATE_LIMIT=60

# --- Admin Configuration ---
ADMIN_EMAIL=admin@tonghua.org
