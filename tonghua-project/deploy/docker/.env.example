# ============================================
# Tonghua Public Welfare — Environment Variables
# ============================================
#
# IMPORTANT: THIS FILE IS FOR EXAMPLE PURPOSES ONLY.
# NEVER commit real secrets to version control.
# Use Docker Secrets or a secure vault (e.g., HashiCorp Vault, AWS Secrets Manager) in production.
#
# For local development:
#   1. Copy this file to .env
#   2. Fill in secure values
#   3. Add .env to your .gitignore
#
# For Docker Swarm/Production:
#   1. Create Docker Secrets for sensitive values (e.g., echo "secret" | docker secret create db_password -)
#   2. Reference secrets in docker-compose.yml (secrets: [db_password])
#   3. Do not use this .env file for production secrets.

# --- Application ---
APP_NAME=tonghua-public-welfare
APP_ENV=development
APP_DEBUG=true
# Generate a secure random string (e.g., 32 bytes hex)
# Command: openssl rand -hex 32
APP_SECRET_KEY=
APP_PORT=8000

# --- Database (MySQL 8.0) ---
# NOTE: In production, these secrets should be injected via Docker Secrets or mounted files.
# Do not pass passwords via environment variables if possible.
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=tonghua
# Generate secure password: openssl rand -base64 32
MYSQL_PASSWORD=
MYSQL_DATABASE=tonghua_db
# Connection URL is constructed programmatically in the app or via secrets
# DATABASE_URL=mysql+aiomysql://...

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
# Generate secure password
REDIS_PASSWORD=
REDIS_DB=0

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=tonghua
# Generate secure password
RABBITMQ_PASSWORD=

# --- JWT ---
# Generate RSA keys:
# openssl genpkey -algorithm RSA -out jwt_private.pem -pkeyopt rsa_keygen_bits:2048
# openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Load content as single-line string with newlines replaced by \n
JWT_SECRET_KEY=
JWT_PUBLIC_KEY=
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption (AES-256-GCM) ---
# Generate 32-byte hex key: openssl rand -hex 32
ENCRYPTION_KEY=
CHILD_DATA_ENCRYPTION_KEY=

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://tonghua.org

# --- Frontend API URL for CSP ---
# Used by frontend Nginx to allow external API calls in connect-src
# Leave empty for same-origin only (recommended for most setups)
# Example: https://api.tonghua.org
API_URL=

# --- Object Storage (Alibaba Cloud OSS) ---
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# Securely manage these keys
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=tonghua-public-welfare
OSS_CDN_DOMAIN=cdn.tonghua.org

# --- WeChat Pay ---
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_CERT_PATH=/certs/wechat_pay
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# --- Alipay ---
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- PayPal ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# --- Email (for notifications) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@tonghua.org
# Securely manage this password
SMTP_PASSWORD=
SMTP_FROM_NAME=Tonghua Public Welfare
SMTP_FROM_EMAIL=noreply@tonghua.org

# --- Rate Limiting ---
RATE_LIMIT_GLOBAL_PER_SECOND=1000
RATE_LIMIT_USER_PER_MINUTE=60
RATE_LIMIT_IP_PER_SECOND=20

# --- Admin ---
ADMIN_EMAIL=admin@tonghua.org
# Change on first login
SUPER_ADMIN_DEFAULT_PASSWORD=
