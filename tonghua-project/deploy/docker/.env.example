# ============================================
# Tonghua Public Welfare — Environment Variables
# ============================================

# --- Application ---
APP_NAME=tonghua-public-welfare
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-secure-random-string
APP_PORT=8000

# --- Database (MySQL 8.0) ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=tonghua
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=tonghua_db
DATABASE_URL=mysql+aiomysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DATABASE}

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_DB=0
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=tonghua
RABBITMQ_PASSWORD=change-me
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/

# --- JWT ---
JWT_SECRET_KEY=change-me-to-rsa-private-key
JWT_PUBLIC_KEY=change-me-to-rsa-public-key
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption (AES-256-GCM) ---
ENCRYPTION_KEY=change-me-to-32-byte-hex-string
CHILD_DATA_ENCRYPTION_KEY=change-me-to-separate-32-byte-hex-string

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://tonghua.org

# --- Object Storage (Alibaba Cloud OSS) ---
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=change-me
OSS_ACCESS_KEY_SECRET=change-me
OSS_BUCKET_NAME=tonghua-public-welfare
OSS_CDN_DOMAIN=cdn.tonghua.org

# --- WeChat Pay ---
WECHAT_PAY_MCH_ID=change-me
WECHAT_PAY_API_KEY=change-me
WECHAT_PAY_CERT_PATH=/certs/wechat_pay
WECHAT_APP_ID=change-me
WECHAT_APP_SECRET=change-me

# --- Alipay ---
ALIPAY_APP_ID=change-me
ALIPAY_PRIVATE_KEY=change-me
ALIPAY_PUBLIC_KEY=change-me
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_change-me
STRIPE_PUBLISHABLE_KEY=pk_test_change-me
STRIPE_WEBHOOK_SECRET=whsec_change-me

# --- PayPal ---
PAYPAL_CLIENT_ID=change-me
PAYPAL_CLIENT_SECRET=change-me
PAYPAL_MODE=sandbox

# --- Email (for notifications) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@tonghua.org
SMTP_PASSWORD=change-me
SMTP_FROM_NAME=Tonghua Public Welfare
SMTP_FROM_EMAIL=noreply@tonghua.org

# --- Rate Limiting ---
RATE_LIMIT_GLOBAL_PER_SECOND=1000
RATE_LIMIT_USER_PER_MINUTE=60
RATE_LIMIT_IP_PER_SECOND=20

# --- Admin ---
ADMIN_EMAIL=admin@tonghua.org
SUPER_ADMIN_DEFAULT_PASSWORD=change-me-on-first-login
