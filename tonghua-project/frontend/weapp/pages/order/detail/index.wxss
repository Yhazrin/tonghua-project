.page { background: #F5F0E8; min-height: 100vh; }
.loading-center { display: flex; align-items: center; justify-content: center; height: 60vh; }
.loading-text { font-size: 28rpx; color: #8C7B6B; }

.status-banner { background: #2C1810; padding: 32rpx 32rpx 24rpx; }
.status-label { display: block; font-size: 36rpx; color: #F5F0E8; font-weight: 500; }
.order-no { display: block; font-size: 24rpx; color: #F5F0E8; opacity: 0.6; margin-top: 8rpx; }

.tab-bar { display: flex; background: #EDE8DF; border-bottom: 2rpx solid #D4C9BA; overflow-x: auto; }
.tab-item { flex-shrink: 0; padding: 24rpx 28rpx; font-size: 24rpx; color: #8C7B6B; white-space: nowrap; }
.tab-item.active { color: #2C1810; border-bottom: 4rpx solid #2C1810; }
.tab-item.disabled { color: #C4B8A8; }

.tab-content { padding: 32rpx; }

.info-card { background: #fff; border-radius: 8rpx; padding: 24rpx; margin-bottom: 24rpx; }
.info-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 2rpx solid #F0EBE2; }
.info-row:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: #8C7B6B; }
.info-value { font-size: 26rpx; color: #2C1810; flex: 1; text-align: right; margin-left: 16rpx; }

.section-title { font-size: 24rpx; color: #8C7B6B; letter-spacing: 4rpx; text-transform: uppercase; margin-bottom: 16rpx; margin-top: 24rpx; }

.items-list { background: #fff; border-radius: 8rpx; overflow: hidden; margin-bottom: 24rpx; }
.item-row { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx; border-bottom: 2rpx solid #F0EBE2; }
.item-info { flex: 1; }
.item-name { font-size: 28rpx; color: #2C1810; display: block; }
.item-qty { font-size: 24rpx; color: #8C7B6B; }
.item-price { font-size: 28rpx; color: #2C1810; }
.total-row { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx; background: #FAF7F2; }
.total-label { font-size: 26rpx; color: #8C7B6B; letter-spacing: 2rpx; }
.total-amount { font-size: 36rpx; color: #2C1810; font-weight: 600; }

.action-bar { display: flex; gap: 16rpx; flex-wrap: wrap; margin-top: 24rpx; }
.btn { padding: 20rpx 40rpx; font-size: 26rpx; border-radius: 0; text-align: center; }
.btn-primary { background: #2C1810; color: #F5F0E8; border: none; }
.btn-outline { background: transparent; color: #2C1810; border: 2rpx solid #C4B8A8; }
.btn-danger { background: transparent; color: #8B3A2A; border: 2rpx solid #8B3A2A; }
.btn-full { width: 100%; }

/* Logistics */
.logistics-summary { background: #fff; border-radius: 8rpx; padding: 24rpx; margin-bottom: 24rpx; }
.timeline { padding: 16rpx 0; }
.timeline-item { display: flex; gap: 24rpx; padding-bottom: 32rpx; position: relative; }
.timeline-item::before { content: ''; position: absolute; left: 11rpx; top: 24rpx; bottom: 0; width: 2rpx; background: #D4C9BA; }
.timeline-item:last-child::before { display: none; }
.timeline-dot { width: 24rpx; height: 24rpx; border-radius: 50%; background: #D4C9BA; border: 4rpx solid #EDE8DF; flex-shrink: 0; margin-top: 4rpx; }
.timeline-dot.active { background: #2C1810; border-color: #2C1810; }
.timeline-content { flex: 1; }
.timeline-desc { font-size: 28rpx; color: #2C1810; display: block; }
.timeline-location { font-size: 24rpx; color: #8C7B6B; display: block; margin-top: 4rpx; }
.timeline-time { font-size: 22rpx; color: #A89888; display: block; margin-top: 4rpx; }

/* Review */
.star-row { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.star { font-size: 48rpx; color: #D4C9BA; }
.star.active { color: #8B3A2A; }
.star.sustainability.active { color: #7A6A58; }

.form-field { margin-bottom: 24rpx; }
.field-label { font-size: 24rpx; color: #8C7B6B; letter-spacing: 2rpx; display: block; margin-bottom: 12rpx; }
.field-input { background: #fff; border: 2rpx solid #D4C9BA; padding: 20rpx 24rpx; font-size: 28rpx; color: #2C1810; width: 100%; box-sizing: border-box; }
.field-textarea { background: #fff; border: 2rpx solid #D4C9BA; padding: 20rpx 24rpx; font-size: 28rpx; color: #2C1810; width: 100%; height: 180rpx; box-sizing: border-box; }
.switch-label { font-size: 26rpx; color: #8C7B6B; margin-left: 16rpx; vertical-align: middle; }

/* After Sales */
.type-grid { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 24rpx; }
.type-item { padding: 16rpx 28rpx; border: 2rpx solid #D4C9BA; font-size: 26rpx; color: #2C1810; }
.type-item.active { background: #2C1810; color: #F5F0E8; border-color: #2C1810; }

/* States */
.empty-state { text-align: center; padding: 80rpx 32rpx; }
.empty-text { font-size: 32rpx; color: #8C7B6B; display: block; margin-bottom: 12rpx; }
.empty-sub { font-size: 26rpx; color: #A89888; }

.success-state { text-align: center; padding: 80rpx 32rpx; }
.success-icon { font-size: 80rpx; color: #2C1810; display: block; margin-bottom: 24rpx; }
.success-text { font-size: 36rpx; color: #2C1810; display: block; margin-bottom: 12rpx; }
.success-sub { font-size: 26rpx; color: #8C7B6B; }
