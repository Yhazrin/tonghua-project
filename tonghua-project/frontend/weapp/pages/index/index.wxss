.hero-section {
  padding: 48rpx 0 32rpx;
}
.hero-title {
  font-size: 64rpx;
  display: block;
  margin: 16rpx 0 8rpx;
}
.banner-swiper {
  width: 100%;
  height: 400rpx;
  margin-bottom: 32rpx;
}
.banner-img {
  width: 100%;
  height: 100%;
}
.stats-section {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 0;
  border-top: 1rpx solid #E8DDD0;
  border-bottom: 1rpx solid #E8DDD0;
  margin-bottom: 48rpx;
}
.stat-item {
  text-align: center;
}
.stat-number {
  font-size: 48rpx;
  display: block;
}
.stat-label {
  margin-top: 8rpx;
}
.section-header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 40rpx;
}
.cta-section {
  text-align: center;
  padding: 64rpx 0;
  border-top: 1rpx solid #E8DDD0;
  border-bottom: 1rpx solid #E8DDD0;
  margin: 48rpx 0;
}
.cta-title {
  font-size: 40rpx;
  display: block;
  margin-bottom: 16rpx;
}
.campaign-item {
  margin-bottom: 16rpx;
}
.campaign-name {
  font-size: 32rpx;
  color: #2C1810;
  display: block;
  margin-bottom: 8rpx;
}
.campaign-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
}
