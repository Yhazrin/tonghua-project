.donations-page {
  min-height: 100vh;
  background-color: #F5F0E8;
  padding-bottom: 120rpx;
}

.summary-card {
  background-color: #2C1810;
  color: #F5F0E8;
  margin: 24rpx;
  border-radius: 12rpx;
  padding: 40rpx 30rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.summary-label {
  display: block;
  font-size: 22rpx;
  color: #7A6A58;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.summary-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #5C4033;
}

.summary-note {
  text-align: center;
  font-size: 22rpx;
  color: #7A6A58;
  margin-top: 20rpx;
  font-style: italic;
}

.section-header {
  padding: 20rpx 30rpx 10rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C1810;
}

.donation-list {
  padding: 0 24rpx;
}

.donation-card {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #E8DDD0;
}

.donation-left {
  width: 160rpx;
  border-right: 1rpx solid #E8DDD0;
  padding-right: 20rpx;
  margin-right: 20rpx;
}

.donation-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C1810;
  margin-bottom: 8rpx;
}

.donation-date {
  font-size: 20rpx;
  color: #7A6A58;
}

.donation-right {
  flex: 1;
}

.donation-campaign {
  font-size: 26rpx;
  color: #2C1810;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.donation-message {
  font-size: 24rpx;
  color: #5C4033;
  margin-bottom: 8rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.donation-anonymous {
  font-size: 22rpx;
  color: #7A6A58;
  font-style: italic;
  margin-bottom: 8rpx;
}

.donation-certificate {
  font-size: 22rpx;
  color: #5C4033;
  text-decoration: underline;
  display: inline-block;
}

.empty-wrap {
  padding: 120rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  color: #E8DDD0;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #2C1810;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #7A6A58;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.empty-btn {
  display: inline-block;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #E8DDD0;
  border-top-color: #2C1810;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 12rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #7A6A58;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
}

.no-more-text {
  font-size: 24rpx;
  color: #7A6A58;
}

.donate-fab {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  background-color: #2C1810;
  color: #F5F0E8;
  padding: 24rpx 48rpx;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 20rpx rgba(44, 24, 16, 0.3);
  z-index: 100;
}

.fab-text {
  font-size: 28rpx;
  font-weight: 600;
}
