.orders-page {
  min-height: 100vh;
  background-color: #F5F0E8;
}

.status-tabs {
  display: flex;
  padding: 20rpx 24rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #E8DDD0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.status-tab {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #7A6A58;
  padding: 16rpx 0;
  border-bottom: 3rpx solid transparent;
}

.status-tab.active {
  color: #2C1810;
  font-weight: 600;
  border-bottom-color: #2C1810;
}

.order-list {
  padding: 20rpx 24rpx;
}

.order-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #E8DDD0;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #E8DDD0;
}

.order-no {
  font-family: "IBM Plex Mono", monospace;
  font-size: 24rpx;
  color: #7A6A58;
}

.order-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background-color: #F5F0E8;
  color: #7A6A58;
}

.order-status.status-pending {
  background-color: #FFF3E0;
  color: #E65100;
}

.order-status.status-paid {
  background-color: #E8F5E9;
  color: #2E7D32;
}

.order-status.status-shipped {
  background-color: #E3F2FD;
  color: #1565C0;
}

.order-status.status-completed {
  background-color: #F5F0E8;
  color: #5C4033;
}

.order-items {
  margin-bottom: 16rpx;
}

.order-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.order-item:last-child {
  margin-bottom: 0;
}

.order-item-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  filter: sepia(30%);
}

.order-item-info {
  flex: 1;
}

.order-item-name {
  display: block;
  font-size: 26rpx;
  color: #2C1810;
  margin-bottom: 4rpx;
}

.order-item-qty {
  display: block;
  font-size: 22rpx;
  color: #7A6A58;
}

.order-item-price {
  font-size: 26rpx;
  color: #2C1810;
  font-weight: 600;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #E8DDD0;
}

.order-date {
  font-size: 22rpx;
  color: #7A6A58;
}

.order-total {
  font-size: 28rpx;
  color: #2C1810;
  font-weight: 600;
}

.empty-wrap {
  padding: 120rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  color: #E8DDD0;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #2C1810;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #7A6A58;
  margin-bottom: 40rpx;
}

.empty-btn {
  display: inline-block;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #E8DDD0;
  border-top-color: #2C1810;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 12rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #7A6A58;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
}

.no-more-text {
  font-size: 24rpx;
  color: #7A6A58;
}
