<scroll-view scroll-y class="page-shop-detail">
  <view class="container" wx:if="{{!loading && product}}">

    <!-- Product Images -->
    <swiper class="product-images" indicator-dots="{{product.images.length > 1}}" indicator-color="rgba(245,240,232,0.5)" indicator-active-color="#F5F0E8" autoplay circular bindchange="onImageChange">
      <swiper-item wx:for="{{product.images}}" wx:key="*this">
        <image class="product-images__img sepia-image" src="{{item}}" mode="aspectFill" />
      </swiper-item>
    </swiper>

    <!-- Image Counter -->
    <view class="product-images__counter" wx:if="{{product.images.length > 1}}">
      <text class="product-images__counter-text">{{currentImageIndex + 1}} / {{product.images.length}}</text>
    </view>

    <!-- Product Info -->
    <view class="product-info">
      <text class="product-info__title">{{product.title}}</text>
      <view class="product-info__price-row">
        <view class="product-info__price-wrap">
          <text class="product-info__currency">&yen;</text>
          <text class="product-info__price">{{product.price}}</text>
        </view>
        <text class="product-info__original-price" wx:if="{{product.original_price}}">&yen;{{product.original_price}}</text>
      </view>
      <view class="product-info__stats">
        <text class="product-info__stat">库存 {{product.stock}}</text>
        <text class="product-info__stat">已售 {{product.sales}}</text>
      </view>
      <view class="divider"></view>
      <text class="product-info__desc">{{product.description}}</text>
    </view>

    <!-- Supply Chain -->
    <view class="supply-chain-section">
      <text class="section-number">Trace</text>
      <text class="section-title">供应链溯源</text>
      <text class="section-subtitle">从原料到成品，每一步透明可查</text>
      <view class="divider"></view>

      <view class="timeline">
        <view class="timeline__item" wx:for="{{product.supply_chain}}" wx:key="stage">
          <view class="timeline__left">
            <view class="timeline__dot">
              <text class="timeline__dot-number">{{index + 1}}</text>
            </view>
            <view class="timeline__line" wx:if="{{index < product.supply_chain.length - 1}}"></view>
          </view>
          <view class="timeline__content">
            <text class="timeline__stage">{{item.stage}}</text>
            <text class="timeline__desc">{{item.description}}</text>
            <view class="timeline__meta">
              <view class="timeline__meta-item">
                <text class="timeline__meta-label">地点</text>
                <text class="timeline__meta-value">{{item.location}}</text>
              </view>
            </view>
            <view class="timeline__cert">
              <text class="timeline__cert-badge">{{item.cert}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- Bottom Action Bar -->
    <view class="action-bar-placeholder"></view>
    <view class="action-bar">
      <view class="quantity-control">
        <view class="quantity-btn" bindtap="onMinus">
          <text>-</text>
        </view>
        <text class="quantity-value">{{quantity}}</text>
        <view class="quantity-btn" bindtap="onPlus">
          <text>+</text>
        </view>
      </view>
      <view class="action-bar__buttons">
        <button class="btn-secondary action-bar__btn" bindtap="onAddCart">加入购物车</button>
        <button class="btn-primary action-bar__btn" bindtap="onBuyNow">立即购买</button>
      </view>
    </view>
  </view>

  <!-- Loading -->
  <view class="loading-hint" wx:if="{{loading}}">
    <text class="loading-hint__text">加载中...</text>
  </view>
</scroll-view>
