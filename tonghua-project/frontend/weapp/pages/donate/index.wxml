<view class="page-container">
  <view wx:if="{{\!showResult}}">
    <view class="section-header">
      <text class="section-number">01</text>
      <text class="editorial-title">\u6350\u8D60</text>
    </view>
    <text class="text-muted donate-desc">\u60A8\u7684\u6BCF\u4E00\u5206\u6350\u8D60\u90FD\u5C06\u7528\u4E8E\u652F\u6301\u513F\u7AE5\u827A\u672F\u6559\u80B2\u548C\u53EF\u6301\u7EED\u65F6\u5C1A\u9879\u76EE</text>
    <view class="amount-section">
      <text class="form-label editorial-caption">\u9009\u62E9\u91D1\u989D (\u5143)</text>
      <view class="amount-grid">
        <view class="amount-btn {{selectedAmount===item ? `active` : ``}}" wx:for="{{amounts}}" wx:key="*this" data-amount="{{item}}" bindtap="onAmountSelect">{{item}}</view>
      </view>
      <input class="form-input custom-input" type="number" placeholder="\u81EA\u5B9A\u4E49\u91D1\u989D" value="{{customAmount}}" bindinput="onCustomInput" />
    </view>
    <view class="form-group">
      <text class="form-label editorial-caption">\u7559\u8A00</text>
      <textarea class="form-textarea" placeholder="\u7ED9\u5B69\u5B50\u4EEC\u7684\u795D\u798F..." value="{{message}}" bindinput="onMessageInput" />
    </view>
    <view class="consent-group">
      <checkbox checked="{{anonymous}}" bindchange="onAnonymousChange" />
      <text class="consent-text">\u533F\u540D\u6350\u8D60</text>
    </view>
    <view class="btn-primary submit-btn" bindtap="onSubmit">\u786E\u8BA4\u6350\u8D60</view>
  </view>
  <view class="result-card" wx:if="{{showResult}}">
    <text class="editorial-title result-title">\u611F\u8C22\u60A8\u7684\u5584\u4E3E</text>
    <text class="result-amount">Ą{{donationResult.amount}}</text>
    <text class="text-muted">\u60A8\u7684\u6350\u8D60\u5DF2\u6210\u529F</text>
    <view class="btn-secondary" bindtap="onCloseResult">\u5173\u95ED</view>
  </view>
  <loading loading="{{submitting}}" text="\u652F\u4ED8\u4E2D..." />
</view>
