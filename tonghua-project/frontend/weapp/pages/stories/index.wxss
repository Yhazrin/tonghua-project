/* === Stories Page === */

.page-stories {
  min-height: 100vh;
}

.page-header {
  padding: 40rpx 0 32rpx;
  border-bottom: 2rpx solid var(--color-warm-gray);
  margin-bottom: 32rpx;
}

.artwork-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.artwork-grid__item {
  width: calc(50% - 10rpx);
}

.artwork-card {
  background-color: var(--color-aged-stock);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.artwork-card__image-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.artwork-card__image {
  width: 100%;
  height: 100%;
}

.artwork-card__overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12rpx 16rpx;
  background: linear-gradient(transparent, rgba(26, 26, 22, 0.6));
}

.artwork-card__child-name {
  font-size: 22rpx;
  color: var(--color-paper);
  font-family: 'Courier New', monospace;
}

.artwork-card__body {
  padding: 16rpx;
}

.artwork-card__title {
  display: block;
  font-family: 'Georgia', serif;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-ink);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.artwork-card__meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.artwork-card__campaign {
  font-size: 20rpx;
  color: var(--color-sepia-mid);
}

.artwork-card__like {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 8rpx;
}

.artwork-card__like-icon {
  font-size: 22rpx;
  color: var(--color-rust);
}

.artwork-card__like-count {
  font-family: 'Courier New', monospace;
  font-size: 20rpx;
  color: var(--color-sepia-mid);
}

.loading-hint {
  padding: 60rpx 0;
  text-align: center;
}

.loading-hint__text {
  font-size: 24rpx;
  color: var(--color-sepia-mid);
}

.empty-hint {
  padding: 120rpx 0;
  text-align: center;
}

.empty-hint__text {
  font-size: 28rpx;
  color: var(--color-sepia-mid);
}
