<view class="page-container">
  <loading loading="{{loading}}" />
  <view wx:if="{{\!loading}}">
    <view class="section-header">
      <text class="section-number">01</text>
      <text class="editorial-title">\u53EF\u6301\u7EED\u5546\u54C1</text>
    </view>
    <view class="category-bar">
      <view class="cat-item {{currentCategory===`` ? `active` : ``}}" data-cat="" bindtap="onCategoryTap">\u5168\u90E8</view>
      <view class="cat-item {{currentCategory===item.id ? `active` : ``}}" wx:for="{{categories}}" wx:key="id" data-cat="{{item.id}}" bindtap="onCategoryTap">{{item.name}}</view>
    </view>
    <view class="products-grid">
      <product-card wx:for="{{products}}" wx:key="id" product="{{item}}" bind:tap="onProductTap" bind:addcart="onAddCart" />
    </view>
    <empty-state wx:if="{{products.length===0}}" text="\u6682\u65E0\u5546\u54C1" />
    <view class="load-more" wx:if="{{hasMore && products.length>0}}">
      <text class="editorial-caption">\u52A0\u8F7D\u66F4\u591A...</text>
    </view>
  </view>
</view>
