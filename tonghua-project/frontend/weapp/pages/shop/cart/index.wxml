<view class="page-container">
  <loading loading="{{loading}}" />
  <view wx:if="{{\!loading}}">
    <view class="section-header">
      <text class="section-number">01</text>
      <text class="editorial-title">\u8D2D\u7269\u8F66</text>
    </view>
    <view class="cart-list">
      <view class="cart-item card" wx:for="{{cartItems}}" wx:key="product.id">
        <image class="cart-img" src="{{item.product.imageUrl}}" mode="aspectFill" />
        <view class="cart-info">
          <text class="cart-name">{{item.product.name}}</text>
          <text class="cart-price">Ą{{item.product.price}}</text>
          <view class="qty-control">
            <text class="qty-btn" data-index="{{index}}" data-delta="-1" catchtap="onChangeQty">-</text>
            <text class="qty-num">{{item.quantity}}</text>
            <text class="qty-btn" data-index="{{index}}" data-delta="1" catchtap="onChangeQty">+</text>
          </view>
        </view>
        <text class="remove-btn" data-index="{{index}}" catchtap="onRemove">x</text>
      </view>
    </view>
    <empty-state wx:if="{{cartItems.length===0}}" text="\u8D2D\u7269\u8F66\u662F\u7A7A\u7684" />
    <view class="cart-footer" wx:if="{{cartItems.length > 0}}">
      <text class="cart-total">\u5408\u8BA1: Ą{{getTotal()}}</text>
      <view class="btn-primary" bindtap="onCheckout">\u53BB\u7ED3\u7B97</view>
    </view>
  </view>
</view>
