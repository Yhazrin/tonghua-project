.page { background: #F5F0E8; min-height: 100vh; }

/* Success */
.success-container { padding: 80rpx 32rpx; text-align: center; }
.success-icon { font-size: 100rpx; color: #2C1810; margin-bottom: 32rpx; }
.success-title { font-size: 40rpx; color: #2C1810; font-weight: 500; margin-bottom: 16rpx; }
.success-sub { font-size: 28rpx; color: #8C7B6B; margin-bottom: 16rpx; }
.success-desc { font-size: 26rpx; color: #A89888; line-height: 1.6; margin-bottom: 48rpx; }

/* Form */
.form-container { padding: 32rpx; }
.page-header { margin-bottom: 40rpx; }
.page-title { font-size: 44rpx; color: #2C1810; font-weight: 600; margin-bottom: 12rpx; }
.page-subtitle { font-size: 26rpx; color: #8C7B6B; line-height: 1.6; }

.flow-steps { display: flex; gap: 0; margin-bottom: 40rpx; overflow: hidden; }
.flow-step { flex: 1; background: #EDE8DF; padding: 20rpx 12rpx; text-align: center; border-right: 2rpx solid #D4C9BA; }
.flow-step:last-child { border-right: none; }
.step-num { font-size: 20rpx; color: #8C7B6B; letter-spacing: 2rpx; margin-bottom: 6rpx; }
.step-text { font-size: 22rpx; color: #2C1810; }

.section { margin-bottom: 32rpx; }
.section-title { font-size: 22rpx; color: #8C7B6B; letter-spacing: 4rpx; text-transform: uppercase; margin-bottom: 16rpx; }

.type-chips { display: flex; flex-wrap: wrap; gap: 12rpx; }
.chip { padding: 12rpx 24rpx; border: 2rpx solid #D4C9BA; font-size: 26rpx; color: #2C1810; border-radius: 0; }
.chip.active { background: #2C1810; color: #F5F0E8; border-color: #2C1810; }

.quantity-row { display: flex; align-items: center; gap: 24rpx; }
.qty-btn { width: 64rpx; height: 64rpx; border: 2rpx solid #D4C9BA; display: flex; align-items: center; justify-content: center; font-size: 40rpx; color: #2C1810; }
.qty-value { font-size: 36rpx; color: #2C1810; min-width: 60rpx; text-align: center; }

.condition-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.condition-item { padding: 20rpx; border: 2rpx solid #D4C9BA; font-size: 26rpx; color: #2C1810; text-align: center; }
.condition-item.active { background: #2C1810; color: #F5F0E8; border-color: #2C1810; }

.field-input { background: #fff; border: 2rpx solid #D4C9BA; padding: 20rpx 24rpx; font-size: 28rpx; color: #2C1810; width: 100%; box-sizing: border-box; }
.field-textarea { background: #fff; border: 2rpx solid #D4C9BA; padding: 20rpx 24rpx; font-size: 28rpx; color: #2C1810; width: 100%; height: 160rpx; box-sizing: border-box; }

.btn { padding: 28rpx 48rpx; font-size: 26rpx; letter-spacing: 4rpx; border-radius: 0; text-align: center; }
.btn-primary { background: #2C1810; color: #F5F0E8; border: none; }
.btn-full { width: 100%; margin-top: 8rpx; }
.btn.disabled { opacity: 0.6; }

.action-bar { margin-top: 40rpx; }

/* History */
.history-section { margin-top: 48rpx; border-top: 2rpx solid #D4C9BA; padding-top: 32rpx; }
.history-item { background: #fff; padding: 24rpx; margin-bottom: 16rpx; border-left: 4rpx solid #D4C9BA; }
.history-main { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.history-info { flex: 1; }
.history-type { font-size: 28rpx; color: #2C1810; display: block; }
.history-status { font-size: 22rpx; color: #8C7B6B; }
.history-link { font-size: 24rpx; color: #8B3A2A; }
.history-id { font-size: 22rpx; color: #A89888; }
