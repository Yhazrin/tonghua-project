@import url(`https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=IBM+Plex+Mono:wght@400;500&display=swap`);

page {
  font-family: -apple-system, BlinkMacSystemFont, `IBM Plex Mono`, `PingFang SC`, `Microsoft YaHei`, sans-serif;
  background-color: #F5F0E8;
  color: #3A3226;
  font-size: 28rpx;
  line-height: 1.6;
}

.page-container {
  padding: 32rpx;
  min-height: 100vh;
}

.editorial-title {
  font-family: `Playfair Display`, `PingFang SC`, serif;
  font-weight: 700;
  color: #2C1810;
  letter-spacing: 0.02em;
}

.editorial-caption {
  font-family: `IBM Plex Mono`, monospace;
  font-size: 22rpx;
  color: #7A6A58;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.sepia-image {
  filter: sepia(30%) contrast(95%);
}

.grain-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 9999;
  opacity: 0.03;
  background-image: url(`data:image/svg+xml,...`);
}

.divider {
  width: 60rpx;
  height: 2rpx;
  background-color: #C4B5A1;
  margin: 32rpx 0;
}

.btn-primary {
  background-color: #2C1810;
  color: #F5F0E8;
  font-family: `IBM Plex Mono`, monospace;
  font-size: 24rpx;
  padding: 20rpx 40rpx;
  border: none;
  letter-spacing: 0.05em;
}

.btn-secondary {
  background-color: transparent;
  color: #2C1810;
  font-family: `IBM Plex Mono`, monospace;
  font-size: 24rpx;
  padding: 18rpx 38rpx;
  border: 2rpx solid #2C1810;
  letter-spacing: 0.05em;
}

.section-number {
  font-family: `Playfair Display`, serif;
  font-size: 72rpx;
  color: #D4C5B0;
  line-height: 1;
}

.text-muted {
  color: #9A8B78;
}

.card {
  background-color: #FFFFFF;
  border: 1rpx solid #E8DDD0;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.amount-btn {
  width: 160rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #C4B5A1;
  font-family: `IBM Plex Mono`, monospace;
  font-size: 28rpx;
  color: #3A3226;
}

.amount-btn.active {
  background-color: #2C1810;
  color: #F5F0E8;
  border-color: #2C1810;
}
