<view class="artwork-card" bindtap="onTap">
  <image class="artwork-img sepia-image" src="{{artwork.imageUrl}}" mode="aspectFill" lazy-load />
  <view class="artwork-info">
    <text class="artwork-title">{{artwork.title}}</text>
    <text class="artwork-author editorial-caption">{{artwork.childDisplayName}}</text>
    <view class="artwork-meta">
      <text class="artwork-campaign editorial-caption">{{artwork.campaignName}}</text>
      <view class="artwork-vote" wx:if="{{showVote}}" catchtap="onVote">
        <text class="vote-count">{{artwork.voteCount}}</text>
        <text class="vote-label">\u7968</text>
      </view>
    </view>
  </view>
</view>
