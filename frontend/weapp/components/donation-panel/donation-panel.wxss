.donation-panel {
  margin: 32rpx 0;
}

.donation-panel__grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.donation-panel__amount {
  width: calc(50% - 10rpx);
  padding: 28rpx 0;
  text-align: center;
  background-color: var(--color-aged-stock);
  border: 2rpx solid var(--color-warm-gray);
  border-radius: 4rpx;
}

.donation-panel__amount--active {
  border-color: var(--color-archive-brown);
  background-color: var(--color-archive-brown);
}

.donation-panel__amount--active .donation-panel__amount-symbol,
.donation-panel__amount--active .donation-panel__amount-value {
  color: var(--color-paper);
}

.donation-panel__amount-symbol {
  font-family: 'Courier New', monospace;
  font-size: 24rpx;
  color: var(--color-sepia-mid);
  margin-right: 4rpx;
}

.donation-panel__amount-value {
  font-family: 'Georgia', serif;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-ink);
}

.donation-panel__custom-input {
  width: 100%;
  height: 100%;
  text-align: center;
  font-family: 'Georgia', serif;
  font-size: 36rpx;
  color: var(--color-ink);
}

.donation-panel__amount--active .donation-panel__custom-input {
  color: var(--color-paper);
}
