.artwork-card {
  background: #fff;
  margin-bottom: 24rpx;
  overflow: hidden;
  border: 1rpx solid #E8DDD0;
}
.artwork-img {
  width: 100%;
  height: 400rpx;
  filter: sepia(20%) contrast(95%);
}
.artwork-info {
  padding: 24rpx;
}
.artwork-title {
  font-family: `Playfair Display`, serif;
  font-size: 32rpx;
  color: #2C1810;
  display: block;
  margin-bottom: 8rpx;
}
.artwork-author {
  display: block;
  margin-bottom: 12rpx;
}
.artwork-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.artwork-vote {
  display: flex;
  align-items: center;
  gap: 4rpx;
}
.vote-count {
  font-family: `IBM Plex Mono`, monospace;
  font-size: 24rpx;
  color: #5C4033;
}
.vote-label {
  font-size: 22rpx;
  color: #9A8B78;
}
