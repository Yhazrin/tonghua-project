.status-bar { background: #2C1810; color: #F5F0E8; padding: 24rpx 32rpx; margin-bottom: 24rpx; }
.status-text { font-family: `IBM Plex Mono`, monospace; font-size: 28rpx; }
.order-item { display: flex; gap: 20rpx; padding: 16rpx 0; border-bottom: 1rpx solid #F0E8DC; }
.item-img { width: 120rpx; height: 120rpx; }
.item-info { flex: 1; }
.item-name { font-size: 28rpx; color: #2C1810; display: block; }
.item-qty { display: block; margin: 8rpx 0; }
.item-price { font-family: `IBM Plex Mono`, monospace; color: #5C4033; }
.info-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #F0E8DC; }
.info-label { width: 120rpx; }
.info-value { font-family: `IBM Plex Mono`, monospace; color: #5C4033; }
.trace-btn { text-align: center; margin-top: 32rpx; }
