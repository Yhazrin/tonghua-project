.tab-bar {
  display: flex;
  gap: 32rpx;
  margin-bottom: 32rpx;
  border-bottom: 1rpx solid #E8DDD0;
  padding-bottom: 16rpx;
}
.tab-item {
  font-family: `IBM Plex Mono`, monospace;
  font-size: 26rpx;
  color: #9A8B78;
  padding-bottom: 16rpx;
}
.tab-item.active {
  color: #2C1810;
  border-bottom: 3rpx solid #2C1810;
}
.campaign-card {
  cursor: pointer;
}
.campaign-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}
.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #9A8B78;
}
.dot-active {
  background: #5C8A4D;
}
.campaign-name {
  font-family: `Playfair Display`, serif;
  font-size: 36rpx;
  color: #2C1810;
  display: block;
  margin-bottom: 8rpx;
}
.campaign-desc {
  display: block;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  line-height: 1.5;
}
.campaign-meta {
  display: flex;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0E8DC;
}
