/* === Campaign Detail Page === */

.page-campaign-detail {
  min-height: 100vh;
}

/* Cover Image */
.campaign-cover {
  position: relative;
  width: 100%;
  height: 420rpx;
  margin-bottom: 32rpx;
  border-radius: 4rpx;
  overflow: hidden;
}

.campaign-cover__image {
  width: 100%;
  height: 100%;
}

.campaign-cover__overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: linear-gradient(transparent, rgba(26, 26, 22, 0.5));
  display: flex;
  justify-content: flex-end;
}

.campaign-cover__status {
  padding: 6rpx 18rpx;
  border-radius: 2rpx;
  font-size: 22rpx;
  font-family: 'Courier New', monospace;
  background-color: rgba(26, 26, 22, 0.5);
  color: var(--color-paper);
  border: 1rpx solid rgba(245, 240, 232, 0.3);
}

.campaign-cover__status--active {
  background-color: rgba(76, 132, 86, 0.7);
  border-color: rgba(76, 132, 86, 0.5);
}

/* Campaign Info */
.campaign-info {
  margin-bottom: 36rpx;
}

.campaign-info__title {
  display: block;
  font-family: 'Georgia', serif;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-ink);
  line-height: 1.3;
  margin-bottom: 16rpx;
}

.campaign-info__desc {
  display: block;
  font-size: 26rpx;
  color: var(--color-sepia-mid);
  line-height: 1.8;
}

/* Progress */
.campaign-progress {
  padding: 28rpx;
  background-color: var(--color-aged-stock);
  border: 1rpx solid var(--color-warm-gray);
  border-radius: 4rpx;
  margin-bottom: 32rpx;
}

.campaign-progress__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.campaign-progress__label {
  font-size: 22rpx;
}

.campaign-progress__count {
  font-family: 'Courier New', monospace;
  font-size: 24rpx;
  color: var(--color-ink);
}

.campaign-progress__bar {
  width: 100%;
  height: 12rpx;
  background-color: var(--color-warm-gray);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.campaign-progress__fill {
  height: 100%;
  background-color: var(--color-archive-brown);
  border-radius: 6rpx;
  transition: width 0.6s ease;
}

.campaign-progress__percent {
  display: block;
  text-align: right;
  font-family: 'Courier New', monospace;
  font-size: 22rpx;
  color: var(--color-sepia-mid);
}

/* Stats */
.campaign-stats {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 0;
  border-top: 1rpx solid var(--color-warm-gray);
  border-bottom: 1rpx solid var(--color-warm-gray);
  margin-bottom: 32rpx;
}

.campaign-stat {
  text-align: center;
}

.campaign-stat__number {
  display: block;
  font-family: 'Georgia', serif;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-ink);
  line-height: 1.2;
}

.campaign-stat__label {
  display: block;
  font-size: 22rpx;
  color: var(--color-sepia-mid);
  font-family: 'Courier New', monospace;
  margin-top: 4rpx;
}

/* Dates */
.campaign-dates {
  display: flex;
  gap: 32rpx;
  margin-bottom: 40rpx;
}

.campaign-dates__item {
  flex: 1;
  padding: 20rpx 24rpx;
  background-color: var(--color-aged-stock);
  border: 1rpx solid var(--color-warm-gray);
  border-radius: 2rpx;
}

.campaign-dates__label {
  display: block;
  font-size: 20rpx;
  color: var(--color-sepia-mid);
  font-family: 'Courier New', monospace;
  margin-bottom: 8rpx;
}

.campaign-dates__value {
  display: block;
  font-size: 26rpx;
  color: var(--color-ink);
  font-family: 'Courier New', monospace;
}

/* Actions */
.campaign-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 48rpx;
}

.campaign-actions__btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  border-radius: 2rpx;
}

/* Related Artworks */
.related-section {
  padding-top: 16rpx;
  margin-bottom: 40rpx;
}

.related-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.related-grid__item {
  width: calc(50% - 10rpx);
}

.related-card {
  background-color: var(--color-aged-stock);
  border-radius: 4rpx;
  overflow: hidden;
  border: 1rpx solid var(--color-warm-gray);
}

.related-card__image-wrap {
  position: relative;
  width: 100%;
  height: 260rpx;
  overflow: hidden;
}

.related-card__image {
  width: 100%;
  height: 100%;
}

.related-card__overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8rpx 12rpx;
  background: linear-gradient(transparent, rgba(26, 26, 22, 0.6));
}

.related-card__name {
  font-size: 20rpx;
  color: var(--color-paper);
  font-family: 'Courier New', monospace;
}

.related-card__body {
  padding: 14rpx 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.related-card__title {
  font-family: 'Georgia', serif;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.related-card__meta {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.related-card__heart {
  font-size: 18rpx;
  color: var(--color-rust);
}

.related-card__likes {
  font-family: 'Courier New', monospace;
  font-size: 18rpx;
  color: var(--color-sepia-mid);
}

/* Editorial Footer */
.editorial-footer {
  padding: 40rpx 0;
  text-align: center;
}

.editorial-footer__divider {
  width: 60rpx;
  height: 2rpx;
  background-color: var(--color-warm-gray);
  margin: 0 auto 20rpx;
}

.editorial-footer__name {
  font-size: 20rpx;
  color: var(--color-sepia-mid);
  font-family: 'Courier New', monospace;
}

/* Loading */
.loading-hint {
  padding: 200rpx 0;
  text-align: center;
}

.loading-hint__text {
  font-size: 24rpx;
  color: var(--color-sepia-mid);
}
