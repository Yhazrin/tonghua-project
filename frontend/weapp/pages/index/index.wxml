<view class="page-container">
  <loading loading="{{loading}}" />
  <view wx:if="{{\!loading}}">
    <view class="hero-section">
      <text class="section-number">01</text>
      <text class="editorial-title hero-title">\u7AE5\u753B\u516C\u76CA</text>
      <text class="editorial-caption">\u53EF\u6301\u7EED\u65F6\u5C1A � \u7528\u827A\u672F\u6539\u53D8\u4E16\u754C</text>
      <view class="divider"></view>
    </view>
    <swiper class="banner-swiper" indicator-dots autoplay circular>
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <image class="banner-img sepia-image" src="{{item.imageUrl}}" mode="aspectFill" alt="Banner image" />
      </swiper-item>
    </swiper>
    <view class="stats-section">
      <view class="stat-item">
        <text class="stat-number editorial-title">{{stats.artworkCount}}</text>
        <text class="stat-label editorial-caption">\u4F5C\u54C1</text>
      </view>
      <view class="stat-item">
        <text class="stat-number editorial-title">{{stats.donationTotal}}</text>
        <text class="stat-label editorial-caption">\u5143\u6350\u8D60</text>
      </view>
      <view class="stat-item">
        <text class="stat-number editorial-title">{{stats.participantCount}}</text>
        <text class="stat-label editorial-caption">\u53C2\u4E0E\u8005</text>
      </view>
    </view>
    <view class="section-header">
      <text class="section-number">02</text>
      <text class="editorial-title section-title">\u7CBE\u9009\u4F5C\u54C1</text>
    </view>
    <view class="artworks-grid">
      <artwork-card wx:for="{{featuredArtworks}}" wx:key="id" artwork="{{item}}" bind:tap="onArtworkTap" />
    </view>
    <view class="cta-section">
      <text class="editorial-title cta-title">\u6BCF\u4E00\u7B14\u6350\u8D60\u90FD\u6709\u610F\u4E49</text>
      <text class="text-muted">\u652F\u6301\u5B69\u5B50\u4EEC\u7684\u827A\u672F\u68A6\u60F3\uFF0C\u4FDD\u62A4\u5730\u7403\u7684\u672A\u6765</text>
      <view class="btn-primary" bindtap="onDonate">\u7ACB\u5373\u6350\u8D60</view>
    </view>
    <view class="section-header">
      <text class="section-number">03</text>
      <text class="editorial-title section-title">\u8FDB\u884C\u4E2D\u7684\u6D3B\u52A8</text>
    </view>
    <view class="campaigns-list">
      <view class="campaign-item card" wx:for="{{campaigns}}" wx:key="id" bindtap="onCampaignTap" data-id="{{item.id}}">
        <text class="campaign-name">{{item.name}}</text>
        <text class="editorial-caption">{{item.status}}</text>
        <text class="text-muted campaign-desc">{{item.description}}</text>
      </view>
    </view>
  </view>
</view>
