<scroll-view scroll-y class="page-cart">
  <view class="container">

    <view class="page-header">
      <view class="page-header__row">
        <view>
          <text class="section-number">Cart</text>
          <text class="section-title">购物车</text>
        </view>
        <text class="page-header__clear" wx:if="{{cartItems.length > 0}}" bindtap="onClear">清空</text>
      </view>
    </view>

    <!-- Cart Items -->
    <view class="cart-list" wx:if="{{cartItems.length > 0}}">
      <view
        class="cart-item"
        wx:for="{{cartItems}}"
        wx:key="id"
      >
        <image
          class="cart-item__image sepia-image"
          src="{{item.image_url}}"
          mode="aspectFill"
          alt="{{item.title}}"
          data-id="{{item.id}}"
          bindtap="onItemTap"
        />
        <view class="cart-item__info">
          <text class="cart-item__title" data-id="{{item.id}}" bindtap="onItemTap">{{item.title}}</text>
          <view class="cart-item__price-row">
            <text class="cart-item__price">&yen;{{item.price}}</text>
            <view class="cart-item__quantity">
              <view class="quantity-btn" data-id="{{item.id}}" bindtap="onMinus">
                <text>-</text>
              </view>
              <text class="quantity-value">{{item.quantity}}</text>
              <view class="quantity-btn" data-id="{{item.id}}" bindtap="onPlus">
                <text>+</text>
              </view>
            </view>
          </view>
          <view class="cart-item__subtotal">
            <text class="cart-item__subtotal-text">小计 &yen;{{(item.price * item.quantity).toFixed(2)}}</text>
          </view>
        </view>
        <view class="cart-item__remove" data-id="{{item.id}}" bindtap="onRemove">
          <text>x</text>
        </view>
      </view>
    </view>

    <!-- Empty State -->
    <view class="empty-hint" wx:if="{{!loading && cartItems.length === 0}}">
      <text class="empty-hint__icon">&#128722;</text>
      <text class="empty-hint__text">购物车还是空的</text>
      <button class="btn-primary empty-hint__btn" bindtap="onGoShop">去逛逛</button>
    </view>

    <!-- Bottom Bar -->
    <view class="bottom-bar-placeholder" wx:if="{{cartItems.length > 0}}"></view>
    <view class="bottom-bar" wx:if="{{cartItems.length > 0}}">
      <view class="bottom-bar__info">
        <text class="bottom-bar__label">合计</text>
        <view class="bottom-bar__total">
          <text class="bottom-bar__currency">&yen;</text>
          <text class="bottom-bar__amount">{{subtotal}}</text>
        </view>
      </view>
      <button class="btn-primary bottom-bar__btn" bindtap="onCheckout">
        结算 ({{cartItems.length}})
      </button>
    </view>
  </view>
</scroll-view>
