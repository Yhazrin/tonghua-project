.category-bar {
  display: flex;
  gap: 24rpx;
  overflow-x: auto;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #E8DDD0;
}
.cat-item {
  font-family: `IBM Plex Mono`, monospace;
  font-size: 24rpx;
  color: #9A8B78;
  white-space: nowrap;
  padding: 8rpx 16rpx;
}
.cat-item.active {
  color: #2C1810;
  border-bottom: 2rpx solid #2C1810;
}
.products-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: space-between;
}
.product-card {
  width: calc(50% - 8rpx);
}
.load-more {
  text-align: center;
  padding: 32rpx 0;
}
