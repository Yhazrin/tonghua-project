.cart-item { display: flex; align-items: center; gap: 20rpx; }
.cart-img { width: 160rpx; height: 160rpx; flex-shrink: 0; }
.cart-info { flex: 1; }
.cart-name { font-size: 28rpx; color: #2C1810; display: block; margin-bottom: 8rpx; }
.cart-price { font-family: `IBM Plex Mono`, monospace; font-size: 28rpx; color: #5C4033; display: block; margin-bottom: 12rpx; }
.qty-control { display: flex; align-items: center; gap: 16rpx; }
.qty-btn { width: 48rpx; height: 48rpx; border: 1rpx solid #C4B5A1; display: flex; align-items: center; justify-content: center; font-size: 28rpx; }
.qty-num { font-family: `IBM Plex Mono`, monospace; font-size: 28rpx; min-width: 40rpx; text-align: center; }
.remove-btn { font-size: 32rpx; color: #9A8B78; padding: 16rpx; }
.cart-footer { position: fixed; bottom: 0; left: 0; right: 0; background: #F5F0E8; padding: 24rpx 32rpx; display: flex; justify-content: space-between; align-items: center; border-top: 1rpx solid #E8DDD0; }
.cart-total { font-family: `IBM Plex Mono`, monospace; font-size: 32rpx; color: #2C1810; }
